# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.venv/
venv/
env/

# Tooling
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Claude Code (personal, per-developer settings: permissions, model, MCP allows).
# settings.json here carries a local bypassPermissions mode, so it stays out of the repo
# rather than turning off prompts for everyone who clones.
.claude/settings.json
.claude/settings.local.json

# Node (xstate runtime + emitted-machine smoke tests)
node_modules/
package-lock.json

# Generated output
*.machine.json
*.machine.mjs
out/

# A run writes everything into <outdir>/<PROGRAM-ID>/, and --outdir defaults to ./out
# (already ignored above). These cover a run pointed somewhere else - e.g. --outdir .
*.prefetch.json
*.fetch.json
*.dynamic-calls.json
