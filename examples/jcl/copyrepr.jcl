//COPYREPR JOB (OPS),'IDCAMS COPY',CLASS=A
//*
//* An IDCAMS REPRO copy edge: PROD.CUST.MASTER -> PROD.CUST.BACKUP.
//* The control cards are instream (SYSIN DD *).
//*
//BACKUP   EXEC PGM=IDCAMS
//INDD     DD  DSN=PROD.CUST.MASTER,DISP=SHR
//OUTDD    DD  DSN=PROD.CUST.BACKUP,DISP=(NEW,CATLG,DELETE)
//SYSPRINT DD  SYSOUT=*
//SYSIN    DD  *
  REPRO INFILE(INDD) OUTFILE(OUTDD)
/*
//
